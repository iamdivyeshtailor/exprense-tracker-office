# Application Port
PORT=3000

# Secure Credentials
ADMIN_PASSWORD=admin123
SESSION_SECRET=kd_purchases_super_secret_key_123

# Google Sheets Configuration
# If GOOGLE_SHEETS_SYNC is true and credentials are provided,
# the app will sync with your live Google Sheet instead of the local Excel file.
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_PATH=google-credentials.json

# SMTP Email Notification Settings (for 7-day expiry notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASS=your_email_app_password
NOTIFICATION_EMAIL_TO=recipient_email@kamaldhari.com
